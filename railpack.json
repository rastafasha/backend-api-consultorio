{
  "$schema": "https://railpack.com",
  "steps": {
    "install": {
      "commands": [
        "composer install --no-interaction --prefer-dist --optimize-autoloader"
      ],
      "variables": {
        "RAILPACK_PHP_VERSION": "8.4"
      }
    }
  },
  "packages": [
    "php84-extensions-pdo_mysql",
    "php84-extensions-mbstring"
  ]
}
